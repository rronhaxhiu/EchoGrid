# Copy this file to .env and fill in your values

# PostgreSQL (leave blank to run in-memory only)
DATABASE_URL=postgresql+asyncpg://simuser:simpass@localhost:5432/simdb

POSTGRES_USER=simuser
POSTGRES_PASSWORD=simpass
POSTGRES_DB=simdb

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Migrations (set to "true" to auto-run on startup)
RUN_MIGRATIONS=true

# Groq LLM (for natural-language event generation)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Pest-risk ML (deployment_bundle/models)
PREDICTION_BACKEND=local
# PEST_MODEL_DIR=../deployment_bundle/models
# PREDICTION_HTTP_URL=http://localhost:8080
# VERTEX_PROJECT=
# VERTEX_LOCATION=us-central1
# VERTEX_ENDPOINT_ID=
