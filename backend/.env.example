# Copy this file to .env and fill in your values

# PostgreSQL (leave blank to run in-memory only)
DATABASE_URL=postgresql+asyncpg://simuser:simpass@localhost:5432/simdb

POSTGRES_USER=simuser
POSTGRES_PASSWORD=simpass
POSTGRES_DB=simdb

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Migrations (set to "true" to auto-run on startup)
RUN_MIGRATIONS=true
